<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title }} · Eleven Messenger</title>
    <meta name="description" content="{{ description }}" />
    <meta name="theme-color" content="#fbf6ee" />
    <meta property="og:title" content="Eleven Messenger" />
    <meta property="og:description" content="{{ description }}" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-head">
      <a class="brand" href="/">Eleven Messenger</a>
      <nav class="site-nav">
        <a href="/security/">Security</a>
        <a href="/privacy/">Privacy</a>
      </nav>
    </header>

    <main>{{ content | safe }}</main>

    <footer class="site-foot">
      <p>No ads, no tracking, no big tech. Just your people.</p>
      <p class="foot-links"><a href="/security/">Security</a> · <a href="/privacy/">Privacy</a></p>
    </footer>
  </body>
</html>
