<!doctype html>
<!-- These go to eleven. -->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if htmlTitle %}{{ htmlTitle }}{% else %}{{ title }} · Eleven{% endif %}</title>
    <meta name="description" content="{{ description }}" />
    <meta name="theme-color" content="#fbf6ee" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/icon_32.png" />
    <link rel="apple-touch-icon" href="/assets/icon_256.png" />
    <meta property="og:title" content="Eleven" />
    <meta property="og:description" content="{{ description }}" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-head">
      <a class="brand" href="/">
        <img class="brand-mark" src="/assets/icon_128.png" alt="" width="28" height="28" />
        Eleven
      </a>
      <nav class="site-nav">
        <a href="/security/">Security</a>
        <a href="/privacy/">Privacy</a>
      </nav>
    </header>

    <main>{{ content | safe }}</main>

    <footer class="site-foot">
      <p>No ads, no tracking, no big tech. Just your people.</p>
      <p class="foot-links"><a href="/why-eleven/">Why &ldquo;Eleven&rdquo;?</a> · <a href="/security/">Security</a> · <a href="/privacy/">Privacy</a></p>
    </footer>
  </body>
</html>
